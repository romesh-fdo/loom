{
    "form": {
        "id": "loom-page-blocks-form",
        "class": "loom-page-blocks-form",
        "method": "POST",
        "enctype": "multipart/form-data",
        "attributes": {
            "data-loom-form": "page-blocks-basic",
            "novalidate": false
        }
    },
    "layout": [
        {
            "section": "block",
            "rowClass": "row g-3 mb-3",
            "fields": [
                {
                    "name": "block_name",
                    "colClass": "col-12"
                }
            ]
        },
        {
            "section": "block",
            "rowClass": "row g-3 mb-3",
            "fields": [
                {
                    "name": "block_html",
                    "colClass": "col-12"
                }
            ]
        }
    ],
    "fields": {
        "block_name": {
            "section": "block",
            "type": "text",
            "label": "Block name",
            "id": "field-block-name",
            "wrapperClass": "mb-0",
            "colClass": "col-12",
            "labelClass": "form-label",
            "required": true,
            "disabled": false,
            "readonly": false,
            "validation": [
                "required"
            ],
            "class": "form-control"
        },
        "block_html": {
            "section": "block",
            "type": "dynamic_code",
            "label": "Block HTML",
            "id": "field-block-html",
            "wrapperClass": "mb-0",
            "colClass": "col-12",
            "labelClass": "form-label",
            "required": true,
            "disabled": false,
            "readonly": false,
            "validation": [
                "required"
            ],
            "class": "d-none",
            "attributes": {
                "data-language": "html",
                "spellcheck": "false"
            },
            "help": "HTML template. Highlight text, right-click, and choose Make dynamic."
        }
    }
}
